{
  "name": "tonge-app",
  "version": "1.0.0",
  "description": "Tonge — AI-powered language learning. Speak every tongue.",
  "main": "server.js",
  "scripts": {
    "start":           "node server.js",
    "dev":             "node --watch server.js",
    "test":            "NODE_ENV=test node --test tests/smoke.test.js",
    "icons":           "node assets/generate-icons.js",
    "cap:init":        "npm install && npx cap add ios && npx cap add android",
    "cap:sync":        "npx cap sync",
    "cap:ios":         "npx cap open ios",
    "cap:android":     "npx cap open android",
    "cap:build":       "node assets/generate-icons.js && npx @capacitor/assets generate && npx cap sync",
    "prewarm":         "node scripts/prewarm-content.js",
    "prewarm:force":   "node scripts/prewarm-content.js --force"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^3.0.3",
    "pg": "^8.21.0",
    "resend": "^3.2.0",
    "stripe": "^14.21.0"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^6.2.0"
  },
  "capacitorDependencies": {
    "@capacitor/android": "^6.2.0",
    "@capacitor/core": "^6.2.0",
    "@capacitor/ios": "^6.2.0",
    "@capacitor/push-notifications": "^6.0.2",
    "@capacitor/splash-screen": "^6.0.2",
    "@capacitor/status-bar": "^6.0.2"
  },
  "optionalDependencies": {
    "firebase-admin": "^12.0.0"
  }
}
