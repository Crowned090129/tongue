# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Security ──────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string_at_least_64_chars
ADMIN_PASSWORD=change_this_to_a_strong_admin_password

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Create these in Stripe Dashboard → Products → Add product
STRIPE_PRICE_MONTHLY=price_...    # $9/month
STRIPE_PRICE_YEARLY=price_...     # $79/year

# Success/cancel URLs after Stripe checkout
APP_URL=https://tonge-app.fly.dev
# If frontend is served from a different origin (e.g. separate CDN), set this:
FRONTEND_URL=https://tonge-app.fly.dev

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@tonge.app
EMAIL_FROM_NAME=Tonge
# Support email shown on FAQ and error pages
SUPPORT_EMAIL=support@tonge.app
# Comma-separated list of admin notification emails (optional)
ADMIN_EMAILS=

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
# Get this from Supabase: Settings → Database → Connection String → URI
# Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres
